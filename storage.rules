rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 공용 도구 — 로그인된 모든 사용자가 모든 계약서/생성 파일 접근
    match /contracts/{uid}/{projectId}/{fileName} {
      allow read, write: if request.auth != null;
    }
    match /generated/{uid}/{projectId}/{fileName} {
      allow read, write: if request.auth != null;
    }
  }
}
