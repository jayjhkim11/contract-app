rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /contracts/{uid}/{projectId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /generated/{uid}/{projectId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
